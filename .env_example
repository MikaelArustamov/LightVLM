# ==============================================================================
# LightVLM Environment Configuration Template
# Rename this file to '.env' and fill in your actual credentials before running.
# ==============================================================================

# Your Hugging Face user access token (Required for downloading SD 1.5 and Whisper weights)
# Get your token here: https://huggingface.co
HF_TOKEN=your_huggingface_token_here

# --- TEXT PIPELINE ENGINE ---
# Supported prefixes via LiteLLM: ollama/, llama_cpp/, openai/
TEXT_MODEL=ollama/llama3.1:8b
TEXT_CTX=8192

# --- VISION PIPELINE ENGINE ---
# Multimodal model used for visual reasoning and intelligent document OCR
VISION_MODEL=ollama/llava-phi3
VISION_CTX=4096

# --- EMBEDDING ENGINE (RAG MEMORY) ---
# FastEmbed backend runs locally on CPU out-of-the-box (no Ollama needed)
EMBED_MODEL=fastembed/BAAI/bge-base-en-v1.5

# Alternative Ollama option for embeddings (Uncomment to use instead of FastEmbed):
# EMBED_MODEL=ollama/nomic-embed-text

# --- REMOTE INFRASTRUCTURE HOSTS ---
# 'http://docker.internal' bridges the Docker container to your host machine's Ollama instance.
# If running native Python outside Docker, change this to 'http://localhost:11434'
OLLAMA_HOST=http://docker.internal
